<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SAELABEL App</title>
    <style>
      :root {
        --bg: #f2f6f9;
        --panel: #ffffff;
        --text: #101820;
        --muted: #4d5a66;
        --accent: #0f7b6c;
        --border: #d8dee4;
      }

      body {
        margin: 0;
        font-family: "Segoe UI Variable", "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background:
          radial-gradient(circle at 15% 0%, #dff5f0 0%, transparent 30%),
          radial-gradient(circle at 100% 10%, #e8eef8 0%, transparent 26%),
          var(--bg);
        color: var(--text);
      }

      main {
        max-width: 100vw;
        margin: 0 auto;
        padding: 0.75rem;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem;
        box-shadow: 0 14px 34px rgba(11, 31, 43, 0.08);
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
