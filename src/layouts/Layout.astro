<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SAELABEL App</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #f8fafc;
        --panel: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --accent: #0f766e;
        --border: #e2e8f0;
        --app-vh: 100vh;
      }

      body {
        margin: 0;
        font-family: "Inter", "Segoe UI Variable", "Segoe UI", system-ui, -apple-system, sans-serif;
        background: 
          radial-gradient(circle at 0% 0%, rgba(15, 118, 110, 0.03) 0%, transparent 50%),
          radial-gradient(circle at 100% 100%, rgba(15, 118, 110, 0.03) 0%, transparent 50%),
          var(--bg);
        color: var(--text);
        letter-spacing: -0.01em;
        height: var(--app-vh);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      html { height: var(--app-vh); overflow: hidden; }

      main {
        width: 100%;
        padding: 0.75rem;
        box-sizing: border-box;
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
        height: var(--app-vh);
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem;
        box-shadow: 0 14px 34px rgba(11, 31, 43, 0.08);
        width: 100%;
        height: 100%;
        min-height: 0;
        box-sizing: border-box;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const setAppVh = () => {
          document.documentElement.style.setProperty("--app-vh", `${window.innerHeight}px`);
        };
        setAppVh();
        window.addEventListener("resize", setAppVh, { passive: true });
      })();
    </script>
  </body>
</html>
